{% extends 'base.html.twig' %}

{% block title %}Menus - Vite & Gourmand{% endblock %}

{% block body %}
    <div class="mb-5">
        <h1 class="mb-3">Nos menus</h1>
        <p class="text-muted">
            Découvrez une sélection de menus proposés par Vite & Gourmand.
        </p>
    </div>

    <div class="row g-4">
        {% for menu in menus %}
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h2 class="h5 card-title">{{ menu.titre }}</h2>
                        <p class="card-text">{{ menu.description }}</p>
                        <p class="mb-1"><strong>Thème :</strong> {{ menu.theme }}</p>
                        <p class="mb-1"><strong>Prix minimum :</strong> {{ menu.prix }} €</p>
                        <p class="mb-3"><strong>Nombre minimum de personnes :</strong> {{ menu.personnes }}</p>
                        <a href="{{ path('app_menu_show', {id: menu.id}) }}" class="btn btn-primary">Voir le détail</a>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12">
                <div class="alert alert-info">
                    Aucun menu n’est disponible pour le moment.
                </div>
            </div>
        {% endfor %}
    </div>
{% endblock %}