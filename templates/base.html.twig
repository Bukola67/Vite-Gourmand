<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Vite & Gourmand{% endblock %}</title>

        {% block stylesheets %}
            <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
        {% endblock %}
    </head>
    <body>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand" href="{{ path('app_home') }}">Vite & Gourmand</a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Afficher la navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNavbar">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                    <a class="nav-link {{ app.request.attributes.get('_route') == 'app_home' ? 'active' : '' }}"
                       href="{{ path('app_home') }}">
                        Accueil
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {{ app.request.attributes.get('_route') == 'app_menu' ? 'active' : '' }}"
                       href="{{ path('app_menu') }}">
                        Menus
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {{ app.request.attributes.get('_route') == 'app_contact' ? 'active' : '' }}"
                        href="{{ path('app_contact') }}">
                        Contact
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {{ app.request.attributes.get('_route') == 'app_login' ? 'active' : '' }}"
                        href="{{ path('app_login') }}">
                        Connexion
                     </a>
                </li>
            </ul>
        </div>
    </div>
</nav>

        <main class="container my-5">
            {% block body %}{% endblock %}
        </main>

        <footer class="bg-light border-top py-4 mt-5">
            <div class="container">
                <div class="row">
                    <div class="col-md-6">
                        <h5>Vite & Gourmand</h5>
                        <p class="mb-1">Service traiteur à Bordeaux</p>
                        <p class="mb-0">Horaires : lundi au dimanche</p>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <a href="#" class="text-decoration-none me-3">Mentions légales</a>
                        <a href="#" class="text-decoration-none">CGV</a>
                    </div>
                </div>
            </div>
        </footer>

        {% block javascripts %}
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
        {% endblock %}
    </body>
</html>
